{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "story_content",
  "type": "object",
  "required": ["sections", "characters"],
  "properties": {
    "characters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "avatar": { "type": "string" },
          "full_image": { "type": "string" }
        },
        "required": ["avatar", "full_image"]
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" }
              }
            }
          }
        },
        "required": ["type", "elements"]
      }
    }
  },
  "additionalProperties": true
}
